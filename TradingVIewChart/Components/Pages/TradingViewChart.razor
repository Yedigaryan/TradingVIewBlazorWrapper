@page "/tradingview"
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

<div class="container">
    <div id="tradingViewChart" style="width: 100%; height: 500px;"></div>
</div>

@code {
    private IJSObjectReference? module;
    private DotNetObjectReference<TradingViewChart>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/tradingViewInterop.js");
            await module.InvokeVoidAsync("tradingViewInterop.initializeChart", "tradingViewChart");

            // Example data
            var candlestickData = new[]
            {
                new { open = 10.0, high = 10.63, low = 9.49, close = 9.55, time = 1642427876 },
                new { open = 9.55, high = 10.30, low = 9.42, close = 9.94, time = 1642514276 },
                new { open = 9.94, high = 10.17, low = 9.92, close = 9.78, time = 1642600676 }
            };

            var barData = new[]
            {
                new { open = 10.0, high = 10.63, low = 9.49, close = 9.55, time = 1642427876 },
                new { open = 9.55, high = 10.30, low = 9.42, close = 9.94, time = 1642514276 },
                new { open = 9.94, high = 10.17, low = 9.92, close = 9.78, time = 1642600676 }
            };

            await module.InvokeVoidAsync("tradingViewInterop.setCandlestickData", candlestickData);
            await module.InvokeVoidAsync("tradingViewInterop.setBarData", barData);
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();
        module?.DisposeAsync();
    }
}