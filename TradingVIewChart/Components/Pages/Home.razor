    // ILogger<Index> logger = LoggerFactory.Create(builder => builder.AddConsole()).CreateLogger<Index>();


    private TradingViewChart? myChart;
    private List<Ohlcv> ohlcvData = new List<Ohlcv>();

    private List<Ohlcv> GenerateChartData()
    {
        var random = new Random(42); // Fixed seed for reproducible data
        var data = new List<Ohlcv>();
        var basePrice = 100.0;
        var currentDate = new DateTime(2023, 1, 1);

        for (int i = 0; i < 22; i++)
        {
            // Skip weekends
            while (currentDate.DayOfWeek == DayOfWeek.Saturday || currentDate.DayOfWeek == DayOfWeek.Sunday)
            {
                currentDate = currentDate.AddDays(1);
            }

            // Generate daily price movement (±3%)
            var dailyVolatility = basePrice * 0.03;
            var open = basePrice + random.NextDouble() * dailyVolatility - dailyVolatility / 2;
            var high = open * (1 + random.NextDouble() * 0.02);
            var low = open * (1 - random.NextDouble() * 0.02);
            var close = (high + low) / 2 + (random.NextDouble() - 0.5) * (high - low);
            var volume = random.Next(1000, 5000);

            data.Add(new Ohlcv
            {
                Time = currentDate,
                Open = (decimal)Math.Round(open, 2),
                High = (decimal)Math.Round(high, 2),
                Low = (decimal)Math.Round(low, 2),
                Close = (decimal)Math.Round(close, 2),
                Volume = volume
            });

            basePrice = close;
            currentDate = currentDate.AddDays(1);
        }

        return data;
    }

